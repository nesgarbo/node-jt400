{
  "name": "@nesgarbo/node-jt400",
  "author": "Néstor García Bou <nesgarbo@icloud.com>",
  "version": "6.0.4",
  "description": "JT400 (IBM Toolbox) for NodeJS",
  "type": "module",
  "main": "dist-cjs/index.js",
  "module": "dist-esm/index.js",
  "types": "dist-esm/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist-esm/index.d.ts",
        "default": "./dist-esm/index.js"
      },
      "require": {
        "types": "./dist-cjs/index.d.ts",
        "default": "./dist-cjs/index.js"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/nesgarbo/node-jt400.git"
  },
  "bugs": {
    "url": "https://github.com/nesgarbo/node-jt400/issues"
  },
  "files": [
    "dist-esm",
    "dist-cjs",
    "java/lib"
  ],
  "scripts": {
    "format-verify": "prettier --check ./ts-src/**/*.ts",
    "format": "prettier --write ./ts-src/**/*.ts",
    "lint": "eslint ts-src/**/*.ts",
    "test": "vitest run",
    "integration-test": "vitest run --config vitest.integration.config.ts",
    "build": "tsup",
    "test-compatibility": "node test-mjs.mjs && node test-cjs.cjs && cd /tmp && node $INIT_CWD/test-mjs.mjs && node $INIT_CWD/test-cjs.cjs",
    "clean": "rm -rf dist-esm dist-cjs",
    "build-dev": "tsup --watch",
    "test-dev": "vitest",
    "build-all": "npm run build && npm run build-java",
    "build-java": "ant archive -buildfile ./java",
    "ci": "npm run clean && npm run build && npm run test && npm run test-compatibility"
  },
  "keywords": [
    "typescript",
    "javascript",
    "as400",
    "IBM",
    "java",
    "db2",
    "jdbc",
    "jt400"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "java-bridge": "^2.8.1",
    "JSONStream": "^1.3.5",
    "oops-error": "^2.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^10.3.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "stream-equal": "^2.0.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run lint && npm run format-verify",
      "pre-push": "npm run build && npm run test"
    }
  }
}
